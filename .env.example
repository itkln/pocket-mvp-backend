COMPOSE_PROJECT_NAME=pocket-mvp

POSTGRES_DB=pocket
POSTGRES_USER=pocket
POSTGRES_PASSWORD=pocket_local_password
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
